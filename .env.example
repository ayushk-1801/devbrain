# =========================================================================
# DevBrain backend configuration. Copy to `.env` and fill in.
# =========================================================================

# --- Cognee Cloud. Set your instance URL and API key here.
#     Visit https://cognee.ai to sign up (use code COGNEE-35). ---
COGNEE_BASE_URL=https://your-instance.cognee.ai
COGNEE_API_KEY=

# --- Local mode (used automatically when COGNEE_API_KEY is empty) ---
# Self-hosted Cognee: Kuzu graph + LanceDB vector + SQLite, all file-based.
# LLM + embeddings are served by Google Gemini, so a Gemini API key is
# needed (get one at https://aistudio.google.com/apikey).
GEMINI_API_KEY=
# Optional backup keys — DevBrain rotates to the next key automatically on a
# 429 rate-limit error. Useful on the Gemini free tier (100 embeds/min limit).
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash-exp
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-2
EMBEDDING_DIMENSIONS=768
COGNEE_DATA_DIR=./.cognee/data
COGNEE_SYSTEM_DIR=./.cognee/system
# Single-user local backend (skip multi-tenant auth). Leave as-is for local dev.
ENABLE_BACKEND_ACCESS_CONTROL=false
COGNEE_SKIP_CONNECTION_TEST=true

# --- GitHub ---
# The server's token; tools/endpoints take the repo as a parameter (multi-repo).
GITHUB_TOKEN=
# Optional convenience default for /query when ?repo= is omitted. Not required.
GITHUB_REPO=
GITHUB_WEBHOOK_SECRET=

# --- DevBrain ---
# Tracks which repos have been ingested (multi-repo listing + weekly refresh).
REGISTRY_PATH=./.devbrain/repos.json
# Redis URL for the ARQ job queue (API + worker must share this).
# Use redis://redis:6379 when running via docker-compose; redis://localhost:6379 for local dev.
REDIS_URL=redis://redis:6379
# Absolute or relative path to the local git checkout for git_* tools (git_commit, git_push, etc.)
# Only needed when the DevBrain backend runs on the same machine as the git clone.
# Default is "." (current working directory where uvicorn/docker starts).
LOCAL_REPO_PATH=.
# Current user name to listen to for agent notifications
CURRENT_USER=arpit


# =========================================================================
# DevBrain Platform Service (port 9000) — user auth + instance provisioning
# =========================================================================

# Random secret for JWT signing and Fernet secret encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PLATFORM_SECRET_KEY=

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
# Callback URL to set in GitHub: http://localhost:9000/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:9000/auth/callback

# Frontend URL (used for post-OAuth redirect)
FRONTEND_URL=http://localhost:3000

# SQLite DB path for platform user + instance data
PLATFORM_DB_PATH=./.devbrain/platform.db

# Persistent data dir for tenant instance files (Docker volumes)
PLATFORM_DATA_DIR=/data/platform

# Port range for tenant API containers (one port per user instance)
PLATFORM_PORT_START=8100
PLATFORM_PORT_END=8199

# Docker image to use for tenant containers (built from the project Dockerfile)
DEVBRAIN_IMAGE=devbrain-devbrain-api
